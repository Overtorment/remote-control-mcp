{
	"name": "remote-control-mcp",
	"version": "1.0.0",
	"description": "Desktop remote-control MCP server built with Electrobun",
	"scripts": {
		"start": "electrobun dev",
		"dev": "electrobun dev --watch",
		"build:canary": "electrobun build --env=canary",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write ."
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"buffer": "6.0.3",
		"electrobun": "1.18.1",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/bun": "latest"
	}
}
